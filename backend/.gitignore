# --- DÉPENDANCES (Le plus lourd) ---
node_modules/
**/node_modules/
/vendor/
.pnp
.pnp.*

# --- NEXT.JS / REACT / FRONTEND ---
.next/
**/.next/
/frontend/.next/
/frontend/out/
/frontend/build/
out/
build/
dist/
.cache/
.eslintcache
*.tsbuildinfo
next-env.d.ts

# --- BINAIRES ET ARCHIVES (Anti-blocage GitHub) ---
# On bloque les extensions qui dépassent souvent les 100 Mo
*.node
*.swc
*.exe
*.dll
*.dylib
*.so
*.zip
*.tar.gz
*.rar

# --- ENVIRONNEMENT ET SECRETS ---
.env
.env.*
!.env.example
*.key
*.pem
auth.json
Homestead.json
Homestead.yaml

# --- LARAVEL / BACKEND ---
/public/build
/public/hot
/public/storage
/storage/*.key
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/testing/*
/storage/framework/views/*
/storage/logs/*
/.phpunit.cache
.phpunit.result.cache

# --- LOGS ET DEBUG ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# --- IDE ET SYSTÈME ---
