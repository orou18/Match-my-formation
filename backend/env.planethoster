# PlanetHoster Production Environment
APP_NAME="Match My Formation"
APP_ENV=production
APP_KEY=base64:Hz4Nc/CJDAk0euE9QJYAgfvgTDSSqrKKm1k7ho03eqg=
APP_DEBUG=false
APP_URL=https://votre-domaine.planethoster.net

# Database Configuration (PlanetHoster)
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=votre_bdd_planethoster
DB_USERNAME=votre_user_planethoster
DB_PASSWORD=votre_mdp_planethoster

# Cache Configuration
CACHE_DRIVER=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Mail Configuration (PlanetHoster)
MAIL_MAILER=smtp
MAIL_HOST=mail.planethoster.net
MAIL_PORT=587
MAIL_USERNAME=contact@votre-domaine.planethoster.net
MAIL_PASSWORD=votre_mdp_email
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="contact@votre-domaine.planethoster.net"
