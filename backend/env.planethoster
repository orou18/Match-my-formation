# Configuration pour le déploiement
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# Configuration des médias
MEDIA_DISK=public
THUMBNAIL_DRIVER=intervention

# Configuration API
API_RATE_LIMIT=1000

# Sanctum
SANCTUM_STATEFUL_DOMAINS=votre-domaine.planethoster.net
