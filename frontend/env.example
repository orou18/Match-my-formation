# Configuration pour le développement local
# Copiez ce fichier en .env.local et ajustez les valeurs selon vos besoins

# URL de l'API backend (Laravel)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# URL de l'application frontend
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Environnement
NEXT_PUBLIC_ENVIRONMENT=development

# Configuration pour le débogage
NEXT_PUBLIC_DEBUG=true

# Comptes de test pour le développement
NEXT_PUBLIC_TEST_STUDENT_EMAIL=student@match.com
NEXT_PUBLIC_TEST_STUDENT_PASSWORD=Azerty123!

NEXT_PUBLIC_TEST_CREATOR_EMAIL=creator@match.com
NEXT_PUBLIC_TEST_CREATOR_PASSWORD=Azerty123!

NEXT_PUBLIC_TEST_ADMIN_EMAIL=admin@match.com
NEXT_PUBLIC_TEST_ADMIN_PASSWORD=Azerty123!
